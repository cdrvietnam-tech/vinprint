# Optional: activate Google Tag Manager after the container is approved.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Các giá trị bắt buộc để Worker xác minh chữ ký JWT của Cloudflare Access.
# Team domain có dạng ten-doanh-nghiep.cloudflareaccess.com.
ADMIN_EMAIL=owner@example.com
CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
CF_ACCESS_AUD=your-access-application-audience-tag
